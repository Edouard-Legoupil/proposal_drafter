=======
## ============================================
## SECRETS MANAGEMENT
## ============================================

# For production, use Google Cloud Secret Manager or Azure Key Vault
# Set USE_SECRET_MANAGER="true" to enable
USE_SECRET_MANAGER="false"

# Choose secret provider: "gcp" (default) or "azure"
SECRET_PROVIDER="gcp"

# Google Cloud Secret Manager configuration
SECRET_MANAGER_PROJECT_ID="your-gcp-project-id"

# Azure Key Vault configuration
AZURE_KEY_VAULT_NAME="your-key-vault-name"Proposal Drafter - Environment Variables Configuration
## This file contains example environment variables for development and production
## For production, use Google Cloud Secret Manager or Azure Key Vault

## ============================================
## DEPLOYMENT CONFIGURATION
## ============================================

## Env variable if building a single container for GCP
GCP_PROJECT_ID="your-gcp-project-id"
GAR_LOCATION="europe-west9"
CLOUD_RUN_REGION="europe-west9"
BACKEND_SERVICE_NAME="proposalgen-backend"

## The service account to be used by the app
SERVICE_ACCOUNT="proposalgen-sa@your-gcp-project-id.iam.gserviceaccount.com"

## ============================================
## LLM CONFIGURATION
## ============================================

## Alternative LLM from Google
GEMINI_API_KEY="your-gemini-api-key"

## Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_API_KEY="your-azure-openai-key"
OPENAI_API_VERSION="2024-02-01"
AZURE_DEPLOYMENT_NAME="gpt-4"

## ============================================
## DOCKER & CONTAINER CONFIGURATION
## ============================================

# Docker Registry
DOCKER_REGISTRY_SERVER_URL="https://gcr.io/your-project-id"

# Container Tags
TAG=latest

## ============================================
## FRONTEND CONFIGURATION
## ============================================

# Frontend Configuration
VITE_BACKEND_URL="http://localhost:8502"
# For production, this will be set by Azure App Service or Cloud Run

## ============================================
## DATABASE CONFIGURATION
## ============================================

# Backend Database Variables (used by the application)
DB_USERNAME="postgres"
DB_PASSWORD="postgres"
DB_NAME="proposalgen"
DB_HOST="localhost"
DB_PORT="5432"

# Enable IAM authentication for Google Cloud SQL
ENABLE_IAM_AUTH="false"

## ============================================
## AUTHENTICATION & SECURITY
## ============================================

# JWT Secret for authentication (use 32+ character random string in production)
SECRET_KEY="generate-a-strong-secret-key-with-32+-characters"

# Microsoft Entra ID (Azure AD) Configuration
ENTRA_TENANT_ID="your-tenant-id"
ENTRA_CLIENT_ID="your-client-id"
ENTRA_CLIENT_SECRET="your-client-secret"
ENTRA_REDIRECT_URI="http://localhost:8503/auth/callback"

## ============================================
## SHAREPOINT INTEGRATION
## ============================================

SHAREPOINT_CLIENT_ID="your-sharepoint-client-id"
SHAREPOINT_CLIENT_SECRET="your-sharepoint-client-secret"
SHAREPOINT_TENANT_ID="your-sharepoint-tenant-id"

## ============================================
## FEATURE FLAGS
## ============================================

# Enable debug mode
DEBUG="false"

# Persist incident analysis results to database/storage
PERSIST_ANALYSIS_RESULTS="false"

## ============================================
## SECRETS MANAGEMENT
## ============================================

# For production, use Google Cloud Secret Manager
# Set USE_SECRET_MANAGER="true" to enable
USE_SECRET_MANAGER="false"

# Google Cloud Secret Manager configuration
SECRET_MANAGER_PROJECT_ID="your-gcp-project-id"
